#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int	language;

void	greetuser(void)
{
	char	buf[64];

	memset(buf, 0, sizeof(buf));
	if (language == 1)
		strcpy(buf, "Hyvää päivää ");
	else if (language == 2)
		strcpy(buf, "Goedemiddag! ");
	else
		strcpy(buf, "Hello ");
	strcat(buf, (char *)__builtin_frame_address(0) + 8);
	puts(buf);
}

int	main(int argc, char **argv)
{
	char	buf[76];
	char	*lang;

	if (argc != 3)
		return 1;
	memset(buf, 0, sizeof(buf));
	strncpy(buf, argv[1], 40);
	strncpy(buf + 40, argv[2], 32);
	lang = getenv("LANG");
	if (lang)
	{
		if (memcmp(lang, "fi", 2) == 0)
			language = 1;
		else if (memcmp(lang, "nl", 2) == 0)
			language = 2;
	}
	/* buf is passed to greetuser as a 76-byte by-value struct via rep movsl. */
	greetuser();
	return 0;
}
