#include <stdio.h>
#include <stdlib.h>
#include <string.h>

char *auth = NULL;
char *service = NULL;

int main(void)
{
	char buf[128];

	for (;;)
	{
		printf("%p, %p \n", auth, service);
		if (!fgets(buf, 128, stdin))
			return 0;

		if (memcmp(buf, "auth ", 5) == 0)
		{
			auth = malloc(4);
			auth[0] = '\0';
			if (strlen(buf + 5) < 0x1f)
				strcpy(auth, buf + 5);
		}

		if (memcmp(buf, "reset", 5) == 0)
		{
			free(auth);
		}

		if (memcmp(buf, "service", 6) == 0)
		{
			service = strdup(buf + 7);
		}

		if (memcmp(buf, "login", 5) == 0)
		{
			if (*(int *)(auth + 0x20) == 0)
				fwrite("Password:\n", 1, 10, stdout);
			else
				system("/bin/sh");
		}
	}
}
